#!/usr/bin/env bash
#
# One-liner launch with cale: write a gitignored compare.engines.json that pipes
# cale's command into the web app (as a one-click preset), then launch the app.
# Override cale's location with CALE_DIR=/path/to/cale.
#
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

CALE_DIR="$(cd "${CALE_DIR:-$ROOT/../cale}" && pwd)"
TSX="$CALE_DIR/node_modules/.bin/tsx"
CLI="$CALE_DIR/src/cale/cli.ts"
[ -x "$TSX" ] && [ -f "$CLI" ] || { echo "cale not runnable at $CALE_DIR (set CALE_DIR, run 'npm install' in cale)" >&2; exit 1; }

# the engine config the app (and the compare CLI) read; quotes survive the
# `sh -c` the runner uses, so paths with spaces are safe.
cat > compare.engines.json <<JSON
{
  "cale": "'$TSX' '$CLI' --debug",
  "dagre": "dagre"
}
JSON
echo "wrote compare.engines.json (cale → $CLI)"

npm install --silent
exec npm run app
